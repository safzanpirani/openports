# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Shodan API key
SHODAN_API_KEY=

# Optional: Censys Search credentials
CENSYS_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
CENSYS_COOKIE=

# Optional: ZoomEye API key
ZOOMEYE_API_KEY=
ZOOMEYE_COOKIE=

# Optional: where to send alerts by default
TELEGRAM_CHAT_ID=

# Optional: database URL (future)
DATABASE_URL=

# Optional: protect /api/scan/* endpoints. If set, callers must send
# `Authorization: Bearer <token>`.
ADMIN_TOKEN=

# Scheduler — set to 0 to disable a loop. Run a multi-source scan every N
# minutes (e.g. 360 = every 6h). Queries every enabled source, not just Shodan.
SCAN_INTERVAL_MINUTES=0
# Which sources the scheduled scan queries. Blank = all enabled. Override with a
# comma-separated subset, e.g. "netlas" to keep the cron off Shodan credits.
SCAN_SOURCES=
# Re-fingerprint stored instances every N minutes.
RECHECK_INTERVAL_MINUTES=0
# Skip instances whose last_checked_at is fresher than this many minutes.
RECHECK_STALE_AFTER_MINUTES=60
# Cap concurrent re-fingerprints.
RECHECK_CONCURRENCY=25
# Grace period (seconds) for a delayed scheduler tick before it is skipped.
# APScheduler's 1s default silently drops ticks when the loop is briefly busy.
SCHEDULER_MISFIRE_GRACE_SECONDS=300
